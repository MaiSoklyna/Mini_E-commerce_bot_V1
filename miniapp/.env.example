# Miniapp Environment Variables
# Copy to .env and fill in your values

# Backend API URL (FastAPI proxy)
VITE_SUPABASE_URL=https://your-backend-domain.com
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_EDGE_FUNCTION_URL=https://your-backend-domain.com/functions/v1

# Telegram Bot Username (for login deep-link)
VITE_BOT_USERNAME=FavouriteOfShop_bot
