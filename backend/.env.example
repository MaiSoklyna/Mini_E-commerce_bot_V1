# Backend Environment Variables
# Copy to .env and fill in your values

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=FavouriteOfShop_bot

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=your-secret-key

# App
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Frontend URLs (your Vercel deployment URLs)
WEB_APP_URL=https://your-miniapp.vercel.app
ADMIN_PANEL_URL=https://your-dashboard.vercel.app

# CORS Origins (comma-separated, include your Vercel domains)
CORS_ORIGINS=https://your-miniapp.vercel.app,https://your-dashboard.vercel.app

# Admin Telegram User IDs (comma-separated)
ADMIN_USER_IDS=123456789

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Support
SUPPORT_GROUP_ID=0
